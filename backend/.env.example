PORT=8080
APP_CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require
# Keep this set to the same Supabase Session Pooler URL for Docker Compose.
DATABASE_URL_DOCKER=postgresql://postgres.your-project-ref:your-password@aws-1-us-west-2.pooler.supabase.com:5432/postgres?sslmode=require
# Same Supabase project as the frontend's NEXT_PUBLIC_SUPABASE_URL /
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY — used to verify incoming bearer tokens.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
